---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, summary, tags, repo } = project.data;
---

<Base title={`${title} — Mohamed Souab`} description={summary}>
  <article class="wrap">
    <a class="back" href="/#projects">← back to projects</a>
    <h1>{title}</h1>
    <p class="summary">{summary}</p>
    <div class="meta">
      <span class="tags">{tags.join(' · ')}</span>
      <a class="btn ghost repo" href={repo}>view on github ↗</a>
    </div>
    <hr />
    <div class="prose">
      <Content />
    </div>
  </article>
</Base>

<style>
  article {
    padding: 48px 24px 72px;
  }

  .back {
    font-size: 11.5px;
    color: var(--muted);
  }

  h1 {
    font-family: var(--font-display);
    font-variation-settings: 'ROND' 100;
    font-weight: 900;
    font-size: clamp(28px, 6vw, 40px);
    margin: 22px 0 0;
  }

  .summary {
    color: var(--soft);
    font-size: 13.5px;
    max-width: 560px;
    margin: 14px 0 0;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-top: 18px;
    flex-wrap: wrap;
  }

  .tags {
    font-size: 11px;
    color: var(--accent);
  }

  .repo {
    padding: 6px 13px;
    font-size: 11.5px;
  }

  hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 30px 0 0;
  }
</style>
