---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import AsciiDonut from '../components/AsciiDonut.astro';

const socials = [
  { name: 'Github', href: 'https://github.com/mosouab' },
  { name: 'LinkedIn', href: 'https://linkedin.com/in/mosouab' },
  { name: 'Email', href: 'mailto:mohamed.souab2@gmail.com' },
  { name: 'CV.pdf ↓', href: '/cv.pdf' },
];

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const skills = [
  'Python', 'C/C++', 'ROS 2', 'PyTorch', 'OpenCV', 'PX4 / MAVLink',
  'Gazebo', 'TIA Portal / WinCC', 'STM32 / Arduino', 'Raspberry Pi',
  'FPGA / VHDL', 'MATLAB / Simulink', 'Docker', 'Linux',
];

const timeline = [
  {
    when: '2025 — 2027',
    what: "Master's in EEA — Autonomous Mobile Systems (M2 SAM)",
    where: 'Université Paris-Saclay',
    note: 'The full perception → decision → action chain for autonomous ground and aerial vehicles: control, fault diagnosis, signal & image processing, embedded computing.',
  },
  {
    when: 'apr — jun 2024',
    what: 'Automation engineering intern',
    where: 'Groupe Bel',
    note: 'Migrated Siemens S7-300 PLCs to S7-1500 with minimal production downtime, built a real-time maintenance-KPI tracker (OEE, MTBF, MTTR…), and web-based HMIs on Siemens Unified Panels.',
  },
  {
    when: '2024 — 2025',
    what: 'Licence in electronics, automation & signal processing',
    where: "Université d'Évry Paris-Saclay",
    note: null,
  },
  {
    when: '2022 — 2024',
    what: 'DUT in industrial computing & automated systems',
    where: 'EST Kénitra, Université Ibn Tofail',
    note: 'Where the PLC obsession started.',
  },
];
---

<Base title="Mohamed Souab — robotics, autonomous systems & embedded AI">
  <!-- hero -->
  <header class="hero">
    <div class="wrap hero-grid">
      <div class="hero-text">
        <p class="hello rise">Hey, I'm 👋</p>
        <h1 class="rise d1">Mohamed Souab</h1>
        <p class="tag rise d2">
          Robotics &amp; embedded AI · M2 Autonomous Mobile Systems @ Paris-Saclay · Évry, France
        </p>
        <p class="pitch rise d3">
          I make machines a bit smarter than they need to be — drones that fly
          themselves without GPS, and factory equipment that predicts its own
          breakdowns. By day I program industrial PLCs; by night I argue with ROS 2.
          Currently looking for a 1-year apprenticeship (alternance) — anywhere
          autonomous systems, embedded AI, or smart automation are involved.
        </p>
        <div class="actions rise d4">
          <a class="btn" href="/#projects">see projects →</a>
          <a class="btn ghost" href="/cv.pdf">download cv</a>
        </div>
        <div class="social rise d4">
          <span class="social-label">find me elsewhere</span>
          <div class="social-row">
            {socials.map((s) => (
              <a class="social-btn" href={s.href}>{s.name}</a>
            ))}
          </div>
        </div>
      </div>
      <div class="hero-art rise d3">
        <AsciiDonut />
      </div>
    </div>
  </header>

  <!-- about -->
  <section id="about">
    <div class="wrap">
      <div class="label">About me</div>
      <div class="about-grid">
        <div class="about-bio">
          <p>
            My path has been a straight line through automation: a DUT in industrial
            computing &amp; automated systems in Kénitra, a Licence in electronics
            &amp; automatic control in Évry, and now a Master's at
            <strong>Paris-Saclay</strong> specializing in
            <strong>autonomous mobile systems</strong> — the full perception →
            decision → action chain that lets ground vehicles, drones, and mobile
            robots operate on their own.
          </p>
          <p>
            That's also where I want to work: robotics and autonomous systems,
            applying AI to real-world problems instead of benchmarks — machines that
            perceive, decide, and act in the physical world. An automation internship
            at <strong>Groupe Bel</strong> gave me a taste of what that means in
            production, and the projects below are what it looks like when I get to
            pick the problem. I like systems you can touch — and that occasionally
            fly away.
          </p>
          <p class="reach">This is what I reach for most days:</p>
          <ul class="chips">
            {skills.map((s) => <li>{s}</li>)}
          </ul>
        </div>
        <aside class="facts-card">
          <img
            class="photo"
            src="/profile.jpg"
            alt="Mohamed Souab by the sea at sunset"
            width="240"
            height="240"
            loading="lazy"
          />
          <dl class="facts">
            <div><dt>Status</dt><dd>open to a 1-year alternance</dd></div>
            <div><dt>Focus</dt><dd>autonomous systems · embedded AI</dd></div>
            <div><dt>Based in</dt><dd>Évry, France</dd></div>
            <div><dt>Languages</dt><dd>Arabic (native) · French C2 · English C1</dd></div>
          </dl>
        </aside>
      </div>
    </div>
  </section>

  <!-- experience / education -->
  <section id="path">
    <div class="wrap">
      <div class="label">The path so far</div>
      <ol class="timeline">
        {timeline.map((t) => (
          <li>
            <div class="when">{t.when}</div>
            <div>
              <div class="what">{t.what}</div>
              <div class="where">{t.where}</div>
              {t.note && <p class="note">{t.note}</p>}
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- projects -->
  <section id="projects">
    <div class="wrap">
      <div class="label">Projects</div>
      <p class="section-intro">
        Three things I've built and can talk about for hours. Click one for the
        write-up.
      </p>
      <div class="cards">
        {projects.map((p) => <ProjectCard project={p} />)}
      </div>
    </div>
  </section>

  <!-- notes -->
  <section id="notes">
    <div class="wrap">
      <div class="head-row">
        <div class="label">Recent notes</div>
        <a class="view-all" href="/blog">view all →</a>
      </div>
      <ul class="posts">
        {posts.map((p) => (
          <li>
            <a href={`/blog/${p.id}/`}>{p.data.title}</a>
            <span>{p.data.date.toISOString().slice(0, 10)}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- contact -->
  <section id="contact">
    <div class="wrap">
      <div class="label">Get in touch</div>
      <p class="section-intro">
        Internship offer, project idea, or you just want to talk drones — drop me a
        line. I answer fast.
      </p>
      <a class="btn" href="mailto:mohamed.souab2@gmail.com">say_hello()</a>
    </div>
  </section>
</Base>

<style>
  .hero {
    padding: 64px 0;
    border-bottom: 1px solid var(--border);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.12fr 0.88fr;
    gap: 40px;
    align-items: center;
  }

  .hello {
    color: var(--muted);
    font-size: 13px;
    margin: 0;
  }

  h1 {
    font-family: var(--font-display);
    font-variation-settings: 'ROND' 100;
    font-weight: 900;
    font-size: clamp(40px, 6vw, 64px);
    margin: 10px 0 0;
    letter-spacing: 0.01em;
  }

  .tag {
    color: var(--soft);
    font-size: 13px;
    margin: 16px 0 0;
  }

  .pitch {
    color: var(--soft);
    max-width: 560px;
    margin: 16px 0 0;
  }

  .actions {
    display: flex;
    gap: 10px;
    margin-top: 26px;
  }

  .social {
    margin-top: 28px;
  }

  .social-label {
    display: block;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 10px;
  }

  .social-label::before {
    content: '// ';
  }

  .social-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .social-btn {
    border: 1px solid var(--border-dark);
    border-radius: var(--radius);
    background: var(--surface);
    padding: 6px 12px;
    font-size: 11.5px;
    text-decoration: none;
    color: var(--fg);
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }

  .social-btn:hover {
    background: var(--surface);
    border-color: var(--ink);
    transform: translate(-2px, -2px);
    box-shadow: 3px 3px 0 0 var(--border-dark);
  }

  .hero-art {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 260px;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 40px;
    margin-top: 18px;
    align-items: start;
  }

  .about-bio p {
    color: var(--soft);
    margin: 0 0 14px;
  }

  .facts-card {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    padding: 16px;
  }

  .photo {
    width: 100%;
    height: 360px;
    object-fit: cover;
    object-position: 50% 56%;
    border: 1px solid var(--border-dark);
    border-radius: var(--radius);
    display: block;
  }

  .facts {
    margin: 16px 0 0;
  }

  .facts > div {
    display: flex;
    justify-content: space-between;
    gap: 14px;
    padding: 9px 0;
    border-bottom: 1px dashed var(--border);
  }

  .facts > div:last-child {
    border-bottom: none;
  }

  .facts dt {
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    white-space: nowrap;
  }

  .facts dd {
    margin: 0;
    font-size: 11.5px;
    color: var(--fg);
    text-align: right;
  }

  .reach {
    margin-top: 26px !important;
    font-size: 12px;
    color: var(--muted);
  }

  .timeline {
    list-style: none;
    padding: 0;
    margin: 18px 0 0;
  }

  .timeline li {
    display: grid;
    grid-template-columns: 130px 1fr;
    gap: 18px;
    padding: 16px 0;
    border-bottom: 1px dashed var(--border);
  }

  .timeline li:last-child {
    border-bottom: none;
  }

  .when {
    font-size: 11px;
    color: var(--muted);
    padding-top: 2px;
  }

  .what {
    color: var(--ink);
    font-size: 13px;
    font-weight: 500;
  }

  .where {
    font-size: 11.5px;
    color: var(--accent);
    margin-top: 2px;
  }

  .note {
    font-size: 12px;
    color: var(--soft);
    margin: 8px 0 0;
  }

  .section-intro {
    color: var(--soft);
    font-size: 13px;
    margin: 14px 0 0;
    max-width: 520px;
  }

  .cards {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 14px;
    margin-top: 22px;
  }

  .head-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .view-all {
    font-size: 11.5px;
    color: var(--muted);
  }

  .posts {
    list-style: none;
    padding: 0;
    margin: 12px 0 0;
  }

  .posts li {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    padding: 11px 0;
    border-bottom: 1px dashed var(--border);
  }

  .posts li:last-child {
    border-bottom: none;
  }

  .posts span {
    font-size: 11px;
    color: var(--muted);
    white-space: nowrap;
  }

  #contact .btn {
    margin-top: 20px;
  }

  @media (max-width: 920px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .hero-art {
      display: none;
    }
    .cards {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 620px) {
    .cards { grid-template-columns: 1fr; }
    .about-grid { grid-template-columns: 1fr; }
    .timeline li { grid-template-columns: 1fr; gap: 4px; }
    .actions { flex-wrap: wrap; }
  }
</style>
