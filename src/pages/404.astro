---
import Base from '../layouts/Base.astro';
---

<Base title="404 — Mohamed Souab">
  <div class="wrap lost">
    <h1>404</h1>
    <p>Signal lost. This page probably flew out of range.</p>
    <a class="btn ghost" href="/">return_to_launch()</a>
  </div>
</Base>

<style>
  .lost {
    padding: 96px 24px;
    text-align: center;
    min-height: 40vh;
  }

  h1 {
    font-family: var(--font-display);
    font-variation-settings: 'ROND' 100;
    font-weight: 900;
    font-size: 64px;
    margin: 0;
  }

  p {
    color: var(--muted);
    margin: 12px 0 28px;
  }
</style>
