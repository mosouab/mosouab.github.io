---
const links = [
  { name: 'about', href: '/#about' },
  { name: 'projects', href: '/#projects' },
  { name: 'blog', href: '/blog' },
  { name: 'cv', href: '/cv.pdf' },
  { name: 'contact', href: '/#contact' },
];
---

<nav>
  <div class="wrap bar">
    <a class="brand" href="/">mosouab</a>
    <button class="menu-btn" aria-expanded="false" aria-controls="nav-links">.menu()</button>
    <div class="links" id="nav-links">
      {links.map((l) => (
        <a href={l.href}><span class="fn">.{l.name}</span><span class="paren">()</span></a>
      ))}
    </div>
  </div>
</nav>

<script>
  const nav = document.querySelector('nav');
  const btn = document.querySelector('.menu-btn');

  btn?.addEventListener('click', () => {
    const open = nav?.classList.toggle('open');
    btn.setAttribute('aria-expanded', String(open));
    btn.textContent = open ? '.close()' : '.menu()';
  });

  // tapping a link (e.g. an anchor on the same page) should close the menu
  nav?.querySelectorAll('.links a').forEach((a) =>
    a.addEventListener('click', () => {
      nav.classList.remove('open');
      btn?.setAttribute('aria-expanded', 'false');
      if (btn) btn.textContent = '.menu()';
    })
  );
</script>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 10;
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
  }

  .bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 12px;
    padding-bottom: 12px;
  }

  .brand {
    font-family: var(--font-display);
    font-variation-settings: 'ROND' 100;
    font-weight: 900;
    font-size: 17px;
    color: var(--ink);
    text-decoration: none;
  }

  .menu-btn {
    display: none;
    background: none;
    border: 1px solid var(--border-dark);
    border-radius: var(--radius);
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg);
    padding: 5px 10px;
    cursor: pointer;
  }

  .links {
    display: flex;
    gap: 14px;
    font-size: 11.5px;
  }

  .links a {
    text-decoration: none;
    color: var(--fg);
  }

  .links a:hover .fn {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .paren {
    color: var(--muted);
  }

  @media (max-width: 560px) {
    .bar {
      flex-wrap: wrap;
    }

    .menu-btn {
      display: inline-block;
    }

    .links {
      display: none;
      width: 100%;
      flex-direction: column;
      gap: 10px;
      font-size: 12.5px;
      margin-top: 12px;
      padding: 12px 0 6px;
      border-top: 1px dashed var(--border);
    }

    nav.open .links {
      display: flex;
    }
  }
</style>
