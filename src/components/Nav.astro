---
const links = [
  { name: 'about', href: '/#about' },
  { name: 'projects', href: '/#projects' },
  { name: 'blog', href: '/blog' },
  { name: 'cv', href: '/cv.pdf' },
  { name: 'contact', href: '/#contact' },
];
---

<nav>
  <div class="wrap bar">
    <a class="brand" href="/">mosouab</a>
    <div class="links">
      {links.map((l) => (
        <a href={l.href}><span class="fn">.{l.name}</span><span class="paren">()</span></a>
      ))}
    </div>
  </div>
</nav>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 10;
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
  }

  .bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 12px;
    padding-bottom: 12px;
  }

  .brand {
    font-family: var(--font-display);
    font-variation-settings: 'ROND' 100;
    font-weight: 900;
    font-size: 17px;
    color: var(--ink);
    text-decoration: none;
  }

  .links {
    display: flex;
    gap: 14px;
    font-size: 11.5px;
  }

  .links a {
    text-decoration: none;
    color: var(--fg);
  }

  .links a:hover .fn {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .paren {
    color: var(--muted);
  }

  @media (max-width: 560px) {
    .links { gap: 9px; font-size: 10.5px; }
  }
</style>
